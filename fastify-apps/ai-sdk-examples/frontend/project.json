{
  "name": "ai-sdk-examples-frontend",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "fastify-apps/ai-sdk-examples/frontend/src",
  "projectType": "application",
  "tags": ["type:frontend", "scope:fastify"],
  "targets": {
    "lint": {},
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "npm run build",
        "cwd": "fastify-apps/ai-sdk-examples/frontend"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run dev",
        "cwd": "fastify-apps/ai-sdk-examples/frontend"
      }
    },
    "preview": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm run preview",
        "cwd": "fastify-apps/ai-sdk-examples/frontend"
      }
    }
  }
}
